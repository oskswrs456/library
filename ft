local function resetToggles()
	if stealEnabled then
		stealEnabled = false
		toggleSwitch(StealKnob, StealFill, StealDot, StealStatus, StealTrackStroke, StealTrack, StealRipple, false)
	end
	if acceptEnabled then
		acceptEnabled = false
		toggleSwitch(AcceptKnob, AcceptFill, AcceptDot, AcceptStatus, AcceptTrackStroke, AcceptTrack, AcceptRipple, false)
	end
end

local function resetProfile()
	ProfilePic.Image = ""
	StatusIndicator.Text = "?"
	StatusIndicator.TextColor3 = Color3.fromRGB(100, 90, 150)
	StatusIndicator.Visible = true
	targetUserId = nil
	targetUsername = ""
	resetToggles()
end

local function lookupUsername(username)
	if username == "" then resetProfile(); return end

	StatusIndicator.Text = "..."
	StatusIndicator.TextColor3 = Color3.fromRGB(180, 170, 100)
	StatusIndicator.Visible = true
	ProfilePic.Image = ""

	task.spawn(function()
		local success, userId = pcall(function()
			return Players:GetUserIdFromNameAsync(username)
		end)

		if UsernameBox.Text:lower() ~= username:lower() then return end

		if success and userId then
			targetUserId = userId
			targetUsername = username
			ProfilePic.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. userId .. "&width=150&height=150&format=png"
			StatusIndicator.Visible = false
			TweenService:Create(PicStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(90, 200, 120)}):Play()
		else
			resetProfile()
			StatusIndicator.Text = "✗"
			StatusIndicator.TextColor3 = Color3.fromRGB(220, 80, 80)
			StatusIndicator.Visible = true
			TweenService:Create(PicStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(200, 60, 60)}):Play()
		end
	end)
end

local lastText = ""
UsernameBox:GetPropertyChangedSignal("Text"):Connect(function()
	local current = UsernameBox.Text
	lastText = current
	TweenService:Create(PicStroke, TweenInfo.new(0.3), {Color = Color3.fromRGB(80, 65, 160)}):Play()
	if current == "" then resetProfile(); return end
	task.delay(0.6, function()
		if UsernameBox.Text == current then lookupUsername(current) end
	end)
end)

