local StealTrack, StealKnob, StealFill, StealDot, StealStatus, StealTrackStroke, StealRipple = createToggle("Steal victims brainrot", 122)
local AcceptTrack, AcceptKnob, AcceptFill, AcceptDot, AcceptStatus, AcceptTrackStroke, AcceptRipple = createToggle("Auto accept trade", 172)

local switchTween = TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)

local function fireRipple(ripple, color)
	ripple.BackgroundColor3 = color
	ripple.Size = UDim2.new(0, 0, 1, 0)
	ripple.Position = UDim2.new(1, 0, 0, 0)
	ripple.BackgroundTransparency = 0.5

	local expandTween = TweenService:Create(ripple, TweenInfo.new(0.4, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
		Size = UDim2.new(1, 0, 1, 0)
	})
	expandTween:Play()

	expandTween.Completed:Connect(function()
		local fadeTween = TweenService:Create(ripple, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			BackgroundTransparency = 1
		})
		fadeTween:Play()
		fadeTween.Completed:Connect(function()
			ripple.Size = UDim2.new(0, 0, 1, 0)
		end)
	end)
end

local function toggleSwitch(knob, fillBar, dot, statusLabel, trackStroke, track, ripple, state)
	if state then
		TweenService:Create(knob, switchTween, {
			Position = UDim2.new(1, -17, 0.5, -7),
			Size = UDim2.new(0, 16, 0, 16),
			BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		}):Play()
		TweenService:Create(fillBar, switchTween, {
			Size = UDim2.new(1, -4, 1, -4),
			BackgroundTransparency = 0.3,
			BackgroundColor3 = Color3.fromRGB(80, 200, 120)
		}):Play()
		TweenService:Create(dot, switchTween, {BackgroundColor3 = Color3.fromRGB(50, 180, 90)}):Play()
		TweenService:Create(trackStroke, switchTween, {Color = Color3.fromRGB(70, 190, 110), Transparency = 0.2}):Play()
		TweenService:Create(track, switchTween, {BackgroundColor3 = Color3.fromRGB(30, 55, 40)}):Play()
		statusLabel.Text = "ON"
		TweenService:Create(statusLabel, switchTween, {TextColor3 = Color3.fromRGB(80, 200, 120)}):Play()
		fireRipple(ripple, Color3.fromRGB(80, 220, 130))
	else
		TweenService:Create(knob, switchTween, {
			Position = UDim2.new(0, 3, 0.5, -7),
			Size = UDim2.new(0, 14, 0, 14),
			BackgroundColor3 = Color3.fromRGB(160, 150, 210)
		}):Play()
		TweenService:Create(fillBar, switchTween, {
			Size = UDim2.new(0, 0, 1, -4),
			BackgroundTransparency = 0.6,
			BackgroundColor3 = Color3.fromRGB(80, 200, 120)
		}):Play()
		TweenService:Create(dot, switchTween, {BackgroundColor3 = Color3.fromRGB(80, 70, 120)}):Play()
		TweenService:Create(trackStroke, switchTween, {Color = Color3.fromRGB(55, 50, 80), Transparency = 0.3}):Play()
		TweenService:Create(track, switchTween, {BackgroundColor3 = Color3.fromRGB(38, 38, 52)}):Play()
		statusLabel.Text = "OFF"
		TweenService:Create(statusLabel, switchTween, {TextColor3 = Color3.fromRGB(100, 100, 120)}):Play()
	end
end

